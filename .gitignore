/target
**/*.rs.bk
Cargo.lock.bak

# Local config & secrets — never commit
ecobee-exporter.toml
.env
*.local.toml

# Persisted refresh + access tokens written by `ecobee-login`.
ecobee-exporter.state.json
*.state.json

# HomeKit bridge pairing data (see `ecobee-homekit-pair`).
homekit-pairings.json

# Copied Home Assistant storage (see `ecobee-homekit-import-ha`).
ha-core.config_entries

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store
